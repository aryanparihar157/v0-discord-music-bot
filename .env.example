# Discord Bot Configuration
# Get these from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# Optional: For testing with a specific guild (server)
# Get this by enabling Developer Mode in Discord settings and right-clicking your server
DISCORD_GUILD_ID=your_server_id_here

# Optional: Spotify Integration
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Optional: Apple Music Integration
# Setup details at https://developer.apple.com/musickit
APPLE_MUSIC_KEY=your_apple_music_key

# Bot Configuration
BOT_PREFIX=/
NODE_ENV=production
